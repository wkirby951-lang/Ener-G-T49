# Ener-G-T-49 Environment Configuration
# Copy this file to .env and update values

# Server
PORT=3000
NODE_ENV=development

# Auth
JWT_SECRET=change-this-to-a-random-secret-string
JWT_EXPIRES_IN=7d

# URLs
PUBLIC_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Email (Resend / SendGrid / Postmark)
# EMAIL_API_KEY=your-api-key-here
# EMAIL_FROM=noreply@yourdomain.com

# Analytics (optional)
# PLAUSIBLE_URL=https://plausible.yourdomain.com
# PLAUSIBLE_DOMAIN=yourdomain.com

# Stripe (payment links are configured directly in the app)
# No API keys needed — using Stripe-hosted checkout links